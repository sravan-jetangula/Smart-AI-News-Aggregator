# ─────────────────────────────────────────────────────
# AI News Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your real .env to version control.
# ─────────────────────────────────────────────────────

# Groq API key — get yours FREE at https://console.groq.com
# If left blank, AI summarization features will be disabled gracefully.
GROQ_API_KEY=your_groq_api_key_here

# SQLite database path (default is fine for local dev)
DATABASE_URL=sqlite:///./ai_news.db

# Environment mode
ENV=development
